NODE_ENV=development
PORT=4000

# Supabase project settings (https://app.supabase.com -> Project Settings -> API)
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=capture-assets

# Web app origin allowed to call this API (CORS) — Next.js dev server 기본 포트
CORS_ORIGIN=http://localhost:3000
