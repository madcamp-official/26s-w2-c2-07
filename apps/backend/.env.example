NODE_ENV=development
PORT=4000

# Supabase project settings (https://app.supabase.com -> Project Settings -> API)
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=capture-assets

# Web app origin(s) allowed to call this API (CORS). 콤마로 여러 개 지정 가능.
# 데스크탑 앱(Electron, http://127.0.0.1:<port>)은 항상 자동으로 허용되므로 여기 넣지 않아도 됨.
CORS_ORIGIN=http://localhost:3000